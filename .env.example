# ── Copy this file to .env.local and fill in the values you need ──────────────
# .env.local is git-ignored. Restart `npm run dev` after changing it.

# Supabase (database + auth + storage) — required for accounts, saving avatars, etc.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Avaturn 3D avatar creator — create a free project/subdomain at developer.avaturn.me
# Leave unset to use the limited shared "demo" subdomain.
NEXT_PUBLIC_AVATURN_SUBDOMAIN=

# OpenAI — ONLY needed for the AI image features:
#   • "✨ Create with AI" avatar generator   (app/api/ai-avatar)
#   • AI tattoo generator                     (app/api/ai-tattoo)
#   • the premade portrait script             (npm run avatars)
# The rest of the site works without it.
OPENAI_API_KEY=

# Stripe (payments / premium unlocks) — optional
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (transactional email) — optional
RESEND_API_KEY=
RESEND_FROM=

# Google Places (reviews ticker) — optional
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Public site URL (used for absolute links / redirects)
NEXT_PUBLIC_SITE_URL=
